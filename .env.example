# Copy to .env (or set these in your shell) and fill in your own values.

# Required: your LLM API key.
RESEARCH_AGENT_API_KEY=your-key-here

# --- Provider presets (pick one) ---

# Groq (recommended: fast, generous free tier). Get a key at https://console.groq.com
RESEARCH_AGENT_BASE_URL=https://api.groq.com/openai/v1
RESEARCH_AGENT_MODEL=openai/gpt-oss-20b

# Web UI only: additional HTTPS LLM hostnames allowed for custom endpoints.
# Groq, Gemini, and OpenAI are already allowed. Use exact hostnames, no URLs.
# RESEARCH_AGENT_ALLOWED_LLM_HOSTS=llm.example.com

# Gemini (small free tier). Get a key at https://aistudio.google.com/apikey
# RESEARCH_AGENT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# RESEARCH_AGENT_MODEL=gemini-2.5-flash-lite

# Optional tuning.
RESEARCH_AGENT_MAX_LLM_ATTEMPTS=3
RESEARCH_AGENT_MAX_ROUNDS=8
RESEARCH_AGENT_MAX_SOURCES=3
# Keep this small on low tokens-per-minute tiers (e.g. Groq free): 1500-2500.
RESEARCH_AGENT_PER_SOURCE_CHARS=2000

# Source diversity.
RESEARCH_AGENT_MIN_DOMAINS=2
RESEARCH_AGENT_MAX_PER_DOMAIN=2

# Performance & quality knobs.
# Prefetch the top N search results in parallel to warm the cache (0 disables).
RESEARCH_AGENT_PREFETCH=3
# Report writing style: brief | standard | deep.
RESEARCH_AGENT_STYLE=standard
# Delay (seconds) between rounds to respect rate limits (raise to 3-5 on 429s).
RESEARCH_AGENT_ROUND_DELAY=0
# Optional: JSON file of extra established/low-evidence domains for ranking.
# See reputation.example.json for the format.
# RESEARCH_AGENT_REPUTATION_FILE=reputation.json

# Fetch cache (directory + time-to-live in seconds; 0 = never expire).
# RESEARCH_AGENT_CACHE_DIR=.research_agent_cache
RESEARCH_AGENT_CACHE_TTL=0

# Optional: custom search API (otherwise free DuckDuckGo is used).
# Providers are tried in order: Tavily -> custom HTTP endpoint -> DuckDuckGo.
# RESEARCH_AGENT_TAVILY_API_KEY=
# RESEARCH_AGENT_SEARCH_ENDPOINT=
# RESEARCH_AGENT_SEARCH_API_KEY=

# Optional: comma-separated domains to never fetch.
# RESEARCH_AGENT_BLOCKED_DOMAINS=example.com,spam.net
